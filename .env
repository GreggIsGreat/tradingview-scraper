# TradingView auth (leave as-is for free anonymous access)
TV_AUTH_TOKEN=unauthorized_user_token

# Symbols to auto-subscribe on startup (comma-separated)
# These get instant price responses from /api/price
AUTO_SUBSCRIBE=OANDA:XAUUSD,OANDA:NAS100USD,COINBASE:BTCUSD

# API server
API_HOST=0.0.0.0
API_PORT=8877

# Tuning
WS_TIMEOUT=20
REQUEST_DELAY=1.5
MAX_BARS_PER_REQUEST=5000
RECONNECT_DELAY=3
MAX_CONCURRENT_CHARTS=3